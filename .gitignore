# ========================
# StudyMate AI — .gitignore
# ========================

# Environment variables (NEVER commit these)
.env
.env.local
.env.production

# Node modules
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Vite cache
frontend/.vite/
